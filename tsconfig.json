{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["vitest/globals"],
    "baseUrl": ".",
    // Resolve the package name to source for typechecking (mirrors the Vite dev alias), so the
    // demo checks against src rather than a possibly-stale built dist/.
    "paths": { "three-vr-player": ["src/index.ts"] }
  },
  "include": ["src", "test", "demo"]
}
