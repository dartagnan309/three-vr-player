{
  "name": "three-vr-player",
  "version": "0.10.3",
  "description": "Embeddable web player for 180/360 and side-by-side/top-bottom 3D video, undistorted on desktop and in WebXR. Built on three.js.",
  "type": "module",
  "license": "MIT",
  "author": "dartagnan309",
  "repository": {
    "type": "git",
    "url": "https://github.com/dartagnan309/three-vr-player"
  },
  "keywords": [
    "webxr",
    "vr",
    "180",
    "360",
    "sbs",
    "stereo",
    "video",
    "three",
    "player",
    "equirectangular"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/three-vr-player.js",
    "./dist/three-vr-player.standalone.js"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/three-vr-player.js",
  "module": "./dist/three-vr-player.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/three-vr-player.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core.js"
    },
    "./standalone": "./dist/three-vr-player.standalone.js"
  },
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "vite build && vite build --config vite.standalone.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "three": ">=0.160.0 <1"
  },
  "optionalDependencies": {
    "hls.js": "^1.5.0"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "hls.js": "^1.5.13",
    "jsdom": "^24.0.0",
    "three": "^0.185.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.5.0"
  }
}
